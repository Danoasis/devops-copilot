# All settings have sane local defaults; override as needed.
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text
JUDGE_MODEL=qwen2.5:7b           # ideally a LARGER model than CHAT_MODEL
COPILOT_DB=data/copilot.db
MAX_AGENT_ITERATIONS=6
LLM_TIMEOUT_S=120
COPILOT_ENABLE_OPS_TOOLS=0       # 1 = MCP server also exposes kubectl tools (Day 5)
COPILOT_ALLOW_WRITES=0           # 1 = allow the gated rollout_restart write action
OTEL_EXPORTER_OTLP_ENDPOINT=     # e.g. http://localhost:4318 (Jaeger)
