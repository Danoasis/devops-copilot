{
  "title": "DevOps Copilot",
  "uid": "devops-copilot",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Triage request rate (req/min)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum by (outcome) (rate(triage_requests_total[5m])) * 60",
        "legendFormat": "{{outcome}}"
      }]
    },
    {
      "id": 2, "type": "timeseries", "title": "Latency p50 / p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(triage_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(triage_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3, "type": "timeseries", "title": "LLM tokens/min",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "expr": "sum by (kind) (rate(llm_tokens_total[5m])) * 60",
        "legendFormat": "{{kind}}"
      }]
    },
    {
      "id": 4, "type": "stat", "title": "In-flight triages",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "sum(triage_in_flight)" }]
    },
    {
      "id": 5, "type": "stat", "title": "Error rate (5m)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [{
        "expr": "sum(rate(triage_requests_total{outcome=\"error\"}[5m])) / clamp_min(sum(rate(triage_requests_total[5m])), 1e-9)"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ]
}
